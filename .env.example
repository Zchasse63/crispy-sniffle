# Scout — environment template (copy to .env.local and fill in)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Server-only: used by scripts/seed.mjs (data seeding). Keep out of the client.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=
# Optional: set as a SUPABASE EDGE FUNCTION SECRET (not here) to enable AI parsing:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-... --project-ref YOUR-PROJECT

# Mapbox — map rendering (public) + style authoring (secret, server-only)
NEXT_PUBLIC_MAPBOX_TOKEN=pk....
NEXT_PUBLIC_MAPBOX_STYLE=mapbox://styles/USER/STYLE_ID
MAPBOX_SECRET_TOKEN=

# Transactional email (owner invites + submission confirmations). Without this,
# every owner email fails silently. A Resend "test" key delivers only to the
# account owner until a domain is verified. Also mirrored into Supabase Vault.
RESEND_API_KEY=

# Optional fallback recipient for TEST-mode email (resend.dev sender). Used only
# when the app_config `email.test_recipient` row is unset; the DB value (settable
# in /admin/flags) takes precedence. In test mode with neither set, sends fail closed.
EMAIL_TEST_RECIPIENT=

# Canonical public site origin — used for owner invite links and the Origin check
# on the public owner endpoints. No trailing slash. Netlify also exposes URL /
# DEPLOY_PRIME_URL automatically; set this so links don't use a deploy-specific host.
NEXT_PUBLIC_SITE_URL=https://scout-gym.netlify.app

# ── Pre-deploy env checklist (Netlify → Site settings → Environment) ──
#   NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY,
#   SUPABASE_SERVICE_ROLE_KEY, RESEND_API_KEY, NEXT_PUBLIC_SITE_URL,
#   NEXT_PUBLIC_MAPBOX_TOKEN  — all must be set before owner invites go out.

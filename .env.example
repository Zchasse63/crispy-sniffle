# Scout — environment template (copy to .env.local and fill in)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Server-only: used by scripts/seed.mjs (data seeding). Keep out of the client.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=
# Optional: set as a SUPABASE EDGE FUNCTION SECRET (not here) to enable AI parsing:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-... --project-ref YOUR-PROJECT
